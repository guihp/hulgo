NEXT_PUBLIC_SUPABASE_URL=https://hzfvciamevimjzuvidcp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only — nunca expor no cliente
N8N_WEBHOOK_APROVACAO=https://seu-n8n.com/webhook/aprovacao

# EvoGo (Evolution GO) — envio outbound do painel
EVOGO_API_URL=https://evogo.iafeoficial.com
EVOGO_GLOBAL_API_KEY=your_global_api_key
# Opcional: pula GET /instance/all (UUID da instância no EvoGo)
EVOGO_INSTANCE_ID=
# Opcional: token da instância (alternativa ao GLOBAL_API_KEY)
EVOGO_INSTANCE_TOKEN=
# Webhook reatado a cada connect (logout/disconnect apagam na EvoGo). Ex: https://n8n.seudominio.com/webhook/ia_hulgo_advocacia
EVOGO_WEBHOOK_URL=
EVOGO_INSTANCE_NAME=testehulgo

# Server-only — token para APIs de integração n8n (header x-integracao-token)
# Alternativa ao valor em app_config.n8n_integracao_token
N8N_INTEGRACAO_TOKEN=your_integracao_token_here

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =============================================================================
# Sistema Hugo — variáveis de ambiente
# Copie para .env.local (dev) ou configure no Coolify (produção).
# =============================================================================

# --- Supabase (obrigatório) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- EvoGo / WhatsApp (obrigatório para envio de mensagens) ---
EVOGO_API_URL=https://evogo.iafeoficial.com
EVOGO_GLOBAL_API_KEY=
EVOGO_INSTANCE_NAME=
# Opcional se já souber id/token da instância (evita lookup em runtime):
EVOGO_INSTANCE_ID=
EVOGO_INSTANCE_TOKEN=
# Webhook reatado a cada connect (logout/disconnect apagam na EvoGo). Ex: https://n8n.seudominio.com/webhook/ia_hulgo_advocacia
EVOGO_WEBHOOK_URL=

# --- n8n (obrigatório para aprovações e controle da IA) ---
N8N_WEBHOOK_APROVACAO=https://n8n.seudominio.com/webhook/aprovacao
N8N_WEBHOOK_CONTROLE_IA=https://n8n.seudominio.com/webhook/controle-ia
N8N_INTEGRACAO_TOKEN=token-secreto-para-apis-integracao

# --- Cron DataJud (obrigatório se usar reconsulta automática) ---
CRON_SECRET=gerar-string-aleatoria-longa

# --- DataJud (opcional — há chave pública embutida no código) ---
DATAJUD_API_KEY=
